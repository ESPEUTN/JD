<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Remote Job Descriptions</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold: #C9A84C;
    --gold-light: #E8C97A;
    --navy: #0B1628;
    --navy-mid: #142036;
    --navy-light: #1E3050;
    --red: #C0392B;
    --red-light: #E74C3C;
    --white: #F5F2EC;
    --gray: #8A9BB0;
  }

  body {
    background: var(--navy);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ── HEADER ── */
  .master-header {
    text-align: center;
    padding: 60px 24px 40px;
    border-bottom: 1px solid rgba(201,168,76,0.2);
  }
  .master-header .eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .master-header h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(36px, 6vw, 64px);
    letter-spacing: 3px;
    color: var(--white);
    line-height: 1;
  }
  .master-header p {
    margin-top: 14px;
    color: var(--gray);
    font-size: 14px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── TABS ── */
  .tabs {
    display: flex;
    justify-content: center;
    gap: 0;
    margin: 40px auto 0;
    max-width: 700px;
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 6px;
    overflow: hidden;
  }
  .tab-btn {
    flex: 1;
    padding: 16px 24px;
    background: transparent;
    border: none;
    color: var(--gray);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    border-right: 1px solid rgba(201,168,76,0.3);
  }
  .tab-btn:last-child { border-right: none; }
  .tab-btn.active {
    background: var(--gold);
    color: var(--navy);
    font-weight: 500;
  }
  .tab-btn:not(.active):hover {
    background: rgba(201,168,76,0.08);
    color: var(--gold-light);
  }

  /* ── CONTENT ── */
  .content { max-width: 820px; margin: 0 auto; padding: 0 24px 80px; }

  .job-doc { display: none; padding-top: 50px; }
  .job-doc.active { display: block; }

  /* ── DOC HEADER ── */
  .doc-header {
    position: relative;
    padding: 40px 44px;
    border-radius: 12px;
    margin-bottom: 36px;
    overflow: hidden;
  }
  .doc-header::before {
    content: '';
    position: absolute; inset: 0;
    opacity: 0.06;
    background-size: 40px 40px;
  }
  .doc-header.primerica { background: linear-gradient(135deg, #C0392B 0%, #8B1A10 100%); }
  .doc-header.primerica::before { background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); }
  .doc-header.infinett { background: linear-gradient(135deg, #C9A84C 0%, #7A5F1A 100%); }
  .doc-header.infinett::before { background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); }

  .doc-header .badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 3px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    padding: 4px 10px;
    margin-bottom: 14px;
    text-transform: uppercase;
  }
  .doc-header h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(28px, 5vw, 44px);
    letter-spacing: 2px;
    line-height: 1;
    margin-bottom: 8px;
  }
  .doc-header .subtitle {
    font-size: 13px;
    opacity: 0.8;
    font-weight: 400;
  }
  .doc-header .meta-tags {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 18px;
  }
  .meta-tag {
    background: rgba(255,255,255,0.12);
    border-radius: 4px;
    padding: 5px 12px;
    font-size: 11px;
    font-family: 'DM Mono', monospace;
    letter-spacing: 1px;
  }

  /* ── SECTION ── */
  .section {
    margin-bottom: 30px;
    border: 1px solid rgba(201,168,76,0.12);
    border-radius: 10px;
    overflow: hidden;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    background: rgba(201,168,76,0.05);
    border-bottom: 1px solid rgba(201,168,76,0.12);
  }
  .section-icon {
    width: 28px; height: 28px;
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px;
    flex-shrink: 0;
  }
  .section-icon.gold { background: rgba(201,168,76,0.2); color: var(--gold); }
  .section-icon.red  { background: rgba(192,57,43,0.2);  color: var(--red-light); }
  .section-title {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
  }
  .section-body { padding: 24px; }

  /* ── LISTS ── */
  ul.styled { list-style: none; padding: 0; }
  ul.styled li {
    padding: 8px 0 8px 22px;
    position: relative;
    font-size: 14px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    color: rgba(245,242,236,0.85);
  }
  ul.styled li:last-child { border-bottom: none; }
  ul.styled li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 16px;
    line-height: 1.5;
  }

  /* ── PAY TABLE ── */
  .pay-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .pay-table th {
    text-align: left;
    padding: 10px 14px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    border-bottom: 1px solid rgba(201,168,76,0.2);
  }
  .pay-table td {
    padding: 12px 14px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    color: rgba(245,242,236,0.85);
    vertical-align: top;
  }
  .pay-table tr:last-child td { border-bottom: none; }
  .pay-table .highlight { color: var(--gold-light); font-weight: 500; }
  .pay-table .note { font-size: 11px; color: var(--gray); margin-top: 3px; }

  /* ── COMMISSION BLOCK ── */
  .comm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
  }
  .comm-card {
    background: var(--navy-mid);
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 8px;
    padding: 18px;
    text-align: center;
  }
  .comm-card .rate {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    color: var(--gold-light);
    letter-spacing: 1px;
    line-height: 1;
  }
  .comm-card .label { font-size: 11px; color: var(--gray); margin-top: 6px; line-height: 1.4; }

  /* ── EXAMPLE BOX ── */
  .example-box {
    background: rgba(201,168,76,0.05);
    border: 1px dashed rgba(201,168,76,0.3);
    border-radius: 8px;
    padding: 18px 20px;
    margin-top: 18px;
  }
  .example-box .example-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .example-box p { font-size: 13px; color: rgba(245,242,236,0.8); }
  .example-box strong { color: var(--gold-light); }

  /* ── RULES BLOCK ── */
  .rule-row {
    display: flex;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 13px;
    align-items: flex-start;
  }
  .rule-row:last-child { border-bottom: none; }
  .rule-label {
    min-width: 130px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    padding-top: 2px;
    flex-shrink: 0;
  }
  .rule-value { color: rgba(245,242,236,0.85); }

  /* ── PRINT ── */
  @media print {
    body { background: white; color: black; }
    .tabs { display: none; }
    .job-doc { display: block !important; page-break-after: always; }
  }

  @media (max-width: 600px) {
    .doc-header { padding: 28px 24px; }
    .section-body { padding: 16px; }
    .comm-grid { grid-template-columns: 1fr 1fr; }
    .rule-row { flex-direction: column; gap: 4px; }
    .rule-label { min-width: unset; }
  }
</style>
</head>
<body>

<div class="master-header">
  <div class="eyebrow">Nick Ruiz · Remote Opportunities</div>
  <h1>Remote Job Descriptions</h1>
  <p>Two separate part-time remote roles — weekly pay, flexible hours, performance-based bonuses.</p>
</div>

<!-- TABS -->
<div class="tabs">
  <button class="tab-btn active" onclick="switchTab('primerica')">🔴 Primerica Recruiting</button>
  <button class="tab-btn" onclick="switchTab('infinett')">🟡 Infinett Nick's Brand</button>
</div>

<div class="content">

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  JOB 1 — PRIMERICA                                     -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <div class="job-doc active" id="doc-primerica">

    <div class="doc-header primerica">
      <div class="badge">Job #1 · Remote · Part-Time</div>
      <h2>Financial Services Recruiting &amp; Appointment Coordinator</h2>
      <div class="subtitle">Support role for Primerica business growth under Nick Ruiz</div>
      <div class="meta-tags">
        <span class="meta-tag">📍 100% Remote</span>
        <span class="meta-tag">🕐 10–20 hrs/week</span>
        <span class="meta-tag">💵 Weekly Pay</span>
        <span class="meta-tag">📈 Commission Eligible</span>
      </div>
    </div>

    <!-- ABOUT -->
    <div class="section">
      <div class="section-header">
        <div class="section-icon gold">📋</div>
        <div class="section-title">About This Role</div>
      </div>
      <div class="section-body">
        <p style="font-size:14px; color:rgba(245,242,236,0.85); line-height:1.8;">
          You'll work directly under Nick Ruiz, a financial services entrepreneur with Primerica, helping grow his team and client base. This is a remote support role focused on outreach, follow-up, and appointment setting. You do <strong style="color:var(--gold-light)">not</strong> need a license to do this job — you will not be selling policies. You find interested people, qualify them, and get them on Nick's calendar.
        </p>
      </div>
    </div>

    <!-- RESPONSIBILITIES -->
    <div class="section">
      <div class="section-header">
        <div class="section-icon gold">✅</div>
        <div class="section-title">Core Responsibilities</div>
      </div>
      <div class="section-body">
        <ul class="styled">
          <li>Reach out to warm and cold leads via social media, text, and phone to generate interest in joining the Primerica business opportunity</li>
          <li>Follow up with prospects who have already expressed interest but haven't committed</li>
          <li>Qualify leads by asking basic screening questions (interest level, availability, employment status)</li>
          <li>Schedule appointments directly on Nick's calendar for business presentations or policy consultations</li>
          <li>Send reminder messages to confirmed appointments to reduce no-shows</li>
          <li>Track leads and appointment outcomes in a simple shared tracker (Google Sheet or CRM)</li>
          <li>Report weekly activity: contacts made, appointments set, and results</li>
          <li>Help source new leads from social platforms, local community groups, or referral networks</li>
        </ul>
      </div>
    </div>

    <!-- WHAT YOU'RE NOT DOING -->
    <div class="section">
      <div class="section-header">
        <div class="section-icon red">🚫</div>
        <div class="section-title">What This Role Does NOT Include</div>
      </div>
      <div class="section-body">
        <ul class="styled">
          <li>You will NOT sell insurance policies or financial products (that requires a license)</li>
          <li>You will NOT make any promises or guarantees about income or products</li>
          <li>You will NOT represent yourself as a Primerica agent</li>
          <li>You will NOT handle any money or financial transactions</li>
        </ul>
      </div>
    </div>

    <!-- PAY STRUCTURE -->
    <div class="section">
      <div class="section-header">
        <div class="section-icon gold">💵</div>
        <div class="section-title">Compensation Structure</div>
      </div>
      <div class="section-body">
        <table class="pay-table">
          <tr>
            <th>Pay Type</th>
            <th>Amount</th>
            <th>Details</th>
          </tr>
          <tr>
            <td><strong>Base Pay</strong></td>
            <td class="highlight">$100–$150 / week</td>
            <td>Paid every Friday. Based on 10–15 hours of documented work.</td>
          </tr>
          <tr>
            <td><strong>Appointment Bonus</strong></td>
            <td class="highlight">$5 per kept appointment</td>
            <td>Only counts if the prospect actually shows up to the meeting with Nick.</td>
          </tr>
          <tr>
            <td><strong>Recruiting Commission</strong></td>
            <td class="highlight">$25 per recruit</td>
            <td>Paid when a referred person officially joins the Primerica team (completes onboarding).</td>
          </tr>
          <tr>
            <td><strong>Policy Referral Bonus</strong></td>
            <td class="highlight">$15–$30 per policy</td>
            <td>Paid when someone you referred signs up for an active policy. Amount depends on policy type.</td>
          </tr>
        </table>

        <div class="example-box">
          <div class="example-label">💡 Weekly Earnings Example</div>
          <p>Base: <strong>$125</strong> + 4 kept appointments (<strong>$20</strong>) + 2 recruits joined (<strong>$50</strong>) + 1 policy referral (<strong>$20</strong>) = <strong>$215 total for the week</strong></p>
        </div>
      </div>
    </div>

    <!-- COMMISSION RULES -->
    <div class="section">
      <div class="section-header">
        <div class="section-icon gold">📐</div>
        <div class="section-title">Commission Rules &amp; Qualifications</div>
      </div>
      <div class="section-body">
        <div class="rule-row">
          <div class="rule-label">Tracking</div>
          <div class="rule-value">All referrals must be logged in the shared tracker before the appointment. No log = no commission.</div>
        </div>
        <div class="rule-row">
          <div class="rule-label">Verification</div>
          <div class="rule-value">Nick must confirm the recruit joined or the policy was signed before any bonus is paid.</div>
        </div>
        <div class="rule-row">
          <div class="rule-label">No Overlap</div>
          <div class="rule-value">If Nick already had the contact in his pipeline, the referral bonus does not apply.</div>
        </div>
        <div class="rule-row">
          <div class="rule-label">Payment Timing</div>
          <div class="rule-value">Commissions are paid in the weekly Friday payment following confirmed results.</div>
        </div>
        <div class="rule-row">
          <div class="rule-label">No Chargebacks</div>
          <div class="rule-value">Once paid, commissions are not taken back unless fraud is discovered.</div>
        </div>
      </div>
    </div>

    <!-- REQUIREMENTS -->
    <div class="section">
      <div class="section-header">
        <div class="section-icon gold">🎯</div>
        <div class="section-title">Requirements</div>
      </div>
      <div class="section-body">
        <ul class="styled">
          <li>Strong written and verbal communication — you'll be texting, DMing, and calling prospects</li>
          <li>Reliable phone and internet connection</li>
          <li>Comfortable with Google Calendar or similar scheduling tools</li>
          <li>Self-motivated — this is remote with no one watching you daily</li>
          <li>Organized and consistent with follow-up (most people need 3–5 touches)</li>
          <li>Positive, professional tone when representing Nick's business</li>
          <li>Preferred: experience in sales, customer service, or appointment setting</li>
        </ul>
      </div>
    </div>

  </div><!-- /primerica -->


  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  JOB 2 — INFINETT NICK'S BRAND                        -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <div class="job-doc" id="doc-infinett">

    <div class="doc-header infinett">
      <div class="badge">Job #2 · Remote · Part-Time</div>
      <h2>Brand &amp; Social Media Marketing Assistant</h2>
      <div class="subtitle">Creative support role for Infinett Nick's Brand (Elevate Empire)</div>
      <div class="meta-tags">
        <span class="meta-tag">📍 100% Remote</span>
        <span class="meta-tag">🕐 8–15 hrs/week</span>
        <span class="meta-tag">💵 Weekly Pay</span>
        <span class="meta-tag">📈 Performance Bonus</span>
      </div>
    </div>

    <!-- ABOUT -->
    <div class="section">
      <div class="section-header">
        <div class="section-icon gold">📋</div>
        <div class="section-title">About This Role</div>
      </div>
      <div class="section-body">
        <p style="font-size:14px; color:rgba(245,242,236,0.85); line-height:1.8;">
          Infinett Nick's Brand is a growing personal brand and online store under the Elevate Empire umbrella. We sell apparel and digital products while building a community-first brand centered on elevation, wealth-building, and personal development. We need a creative marketing assistant who can help manage content, grow our social presence, and promote the store to drive real sales.
        </p>
      </div>
    </div>

    <!-- RESPONSIBILITIES -->
    <div class="section">
      <div class="section-header">
        <div class="section-icon gold">✅</div>
        <div class="section-title">Core Responsibilities</div>
      </div>
      <div class="section-body">
        <ul class="styled">
          <li>Create or repurpose social media content for Instagram, TikTok, and Facebook (posts, reels, stories)</li>
          <li>Write engaging captions that match the brand voice — motivational, sharp, and community-driven</li>
          <li>Schedule and post content on a consistent calendar (3–5 posts per week minimum)</li>
          <li>Engage with followers — respond to comments, DMs, and grow community interaction</li>
          <li>Research trending sounds, hashtags, and content formats relevant to the brand</li>
          <li>Promote active store products and new drops with platform-native creative content</li>
          <li>Monitor and report basic analytics weekly (reach, engagement, click-through)</li>
          <li>Assist with email or SMS campaign copy when needed</li>
          <li>Source or create simple graphic assets using Canva or similar tools</li>
        </ul>
      </div>
    </div>

    <!-- PAY STRUCTURE -->
    <div class="section">
      <div class="section-header">
        <div class="section-icon gold">💵</div>
        <div class="section-title">Compensation Structure</div>
      </div>
      <div class="section-body">
        <table class="pay-table">
          <tr>
            <th>Pay Type</th>
            <th>Amount</th>
            <th>Details</th>
          </tr>
          <tr>
            <td><strong>Base Pay</strong></td>
            <td class="highlight">$75–$125 / week</td>
            <td>Paid every Friday. Based on 8–12 hours of documented work and content output.</td>
          </tr>
          <tr>
            <td><strong>Content Bonus</strong></td>
            <td class="highlight">$5 per viral post</td>
            <td>Any post that reaches 1,000+ organic views earns a $5 bonus. No cap.</td>
          </tr>
          <tr>
            <td><strong>Sales Commission</strong></td>
            <td class="highlight">5% of tracked sales</td>
            <td>On sales directly attributed to your content (using UTM links or promo codes you manage).</td>
          </tr>
          <tr>
            <td><strong>Growth Bonus</strong></td>
            <td class="highlight">$25 per milestone</td>
            <td>Paid when a platform hits a new follower milestone (every +500 new followers).</td>
          </tr>
        </table>

        <div class="example-box">
          <div class="example-label">💡 Weekly Earnings Example</div>
          <p>Base: <strong>$100</strong> + 3 viral posts (<strong>$15</strong>) + $200 in tracked sales (<strong>$10</strong>) + follower milestone hit (<strong>$25</strong>) = <strong>$150 total for the week</strong></p>
        </div>
      </div>
    </div>

    <!-- COMMISSION RULES -->
    <div class="section">
      <div class="section-header">
        <div class="section-icon gold">📐</div>
        <div class="section-title">Performance Rules &amp; Qualifications</div>
      </div>
      <div class="section-body">
        <div class="rule-row">
          <div class="rule-label">Content Output</div>
          <div class="rule-value">Minimum 3 posts per week required to receive full base pay. Below that triggers a prorated deduction.</div>
        </div>
        <div class="rule-row">
          <div class="rule-label">Sales Tracking</div>
          <div class="rule-value">All tracked sales must use assigned UTM links or a personal promo code. Untracked sales are not commissionable.</div>
        </div>
        <div class="rule-row">
          <div class="rule-label">Viral Post Verification</div>
          <div class="rule-value">Screenshots of post analytics must be submitted weekly for bonus verification.</div>
        </div>
        <div class="rule-row">
          <div class="rule-label">Brand Approval</div>
          <div class="rule-value">All content must be approved by Nick before going live until a 30-day track record is established.</div>
        </div>
        <div class="rule-row">
          <div class="rule-label">Payment Timing</div>
          <div class="rule-value">All bonuses paid in the Friday payment following verified results.</div>
        </div>
      </div>
    </div>

    <!-- REQUIREMENTS -->
    <div class="section">
      <div class="section-header">
        <div class="section-icon gold">🎯</div>
        <div class="section-title">Requirements</div>
      </div>
      <div class="section-body">
        <ul class="styled">
          <li>Active and knowledgeable user of Instagram, TikTok, and Facebook</li>
          <li>Comfortable creating content using Canva, CapCut, or similar tools</li>
          <li>Strong copywriting skills — you understand how to write content that converts</li>
          <li>Self-directed — able to manage a content calendar without daily check-ins</li>
          <li>Understanding of personal brand storytelling and community-building</li>
          <li>Bonus: experience with Shopify, eCommerce promotion, or dropshipping brands</li>
          <li>Bonus: experience growing a social media page from scratch</li>
          <li>Must be reliable — consistency is more important than creative genius here</li>
        </ul>
      </div>
    </div>

  </div><!-- /infinett -->

</div><!-- /content -->

<script>
  function switchTab(name) {
    document.querySelectorAll('.job-doc').forEach(d => d.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('doc-' + name).classList.add('active');
    event.currentTarget.classList.add('active');
  }
</script>
</body>
</html>
